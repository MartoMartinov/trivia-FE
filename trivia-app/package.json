{
  "name": "trivia-app",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "tw": "tailwindcss -i src/tailwind.css -o src/tailwind-out.css",
    "tw:watch": "tailwindcss -i src/tailwind.css -o src/tailwind-out.css --watch",
    "start": "npm run tw && concurrently \"npm run tw:watch\" \"ng serve\"",
    "build": "npm run tw && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.15",
