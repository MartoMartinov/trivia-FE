    "@angular/platform-browser-dynamic": "21.2.15",
    "@angular/router": "21.2.15",
    "@aparajita/capacitor-secure-storage": "8.0.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.0",
